# Copy to `.env` and fill in values. Never commit `.env`.

# --- Supabase PostgreSQL (pick one style) ---

# Full URL (recommended on Render). URL-encode special characters in the password.
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Or discrete variables:
# SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres
# SUPABASE_DB_PASSWORD=YOUR_PASSWORD
# SUPABASE_DB_PORT=5432

# Optional: extra hosts (comma-separated)
# ALLOWED_HOSTS=yourapp.onrender.com,example.com

# Optional: CSRF for HTTPS deployments
# CSRF_TRUSTED_ORIGINS=https://yourapp.onrender.com

# Optional: REST API CORS (comma-separated origins for browser tools / external dashboards calling /api/)
# CORS_ALLOWED_ORIGINS=https://yourstorent.co.za,https://www.yourstorent.co.za

# Optional: version string returned by GET /api/v1/health/
# YTR_PLATFORM_VERSION=1.0.0

# Optional: if you put collected static files on a CDN, set base URL (no trailing slash); templates receive ytr_static_cdn_base
# YTR_STATIC_CDN_BASE=https://cdn.example.com

# Optional: allow listing creation without completed document verification (local testing only)
# YTR_REQUIRE_VERIFICATION_TO_LIST=false

# Optional — Cloudinary for user media (avatars, listing images). If unset, uploads use local disk (MEDIA_ROOT).
# Get real values from https://cloudinary.com/ — do not use placeholder cloud names.
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
# URI form is also supported:
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
